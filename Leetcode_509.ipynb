      "source": [
        "class Solution:\n",
        "  def fib(self , n : int) -> int:\n",
        "    if n == 1 or n == 0:\n",
        "      return 1\n",
        "    return self.fib(n-1) + self.fib(n-2)\n",
        "\n",
        "s = Solution()\n",
        "\n",
        "print(s.fib(1))\n",
        "print(s.fib(5))\n",
        "print(s.fib(6))"
      ]
    },
