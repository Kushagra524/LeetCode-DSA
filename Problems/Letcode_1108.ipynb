      "cell_type": "code",
      "source": [
        "class Solution:\n",
        "  def defandIPaddr(self , address : str) -> str:\n",
        "    return address.replace(\".\" , \"[.]\")\n",
        "\n",
        "s = Solution()"
      ],
      "metadata": {
        "id": "wtgHBBnrFE3v"
      },
      "execution_count": 3,
      "outputs": []
    },
